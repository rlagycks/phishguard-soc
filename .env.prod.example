# ─── Image / domain ───────────────────────────────────────────────────────────
APP_IMAGE=ghcr.io/OWNER/REPO:latest
DOMAIN=soc.example.com

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=soc
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=soc_phishing
DATABASE_URL=postgresql://soc:change-this-strong-password@postgres:5432/soc_phishing

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://soc.example.com/auth/callback

# ─── Gmail Watch / Pub/Sub ───────────────────────────────────────────────────
GMAIL_ACCOUNT=your-test-account@gmail.com
PUBSUB_TOPIC=projects/your-gcp-project/topics/gmail-alert-topic
WEBHOOK_TOKEN=generate-a-random-secret-token-here

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_MINUTES=10080

# ─── Dashboard URL ────────────────────────────────────────────────────────────
FRONTEND_URL=https://soc.example.com
STREAMLIT_URL=https://soc.example.com

# ─── AI Model paths inside the app container ─────────────────────────────────
NLP_MODEL_PATH=/app/models/bert
URL_MODEL_PATH=/app/models/url_model.pkl

# ─── Risk Thresholds ──────────────────────────────────────────────────────────
SUSPICIOUS_THRESHOLD=0.40
DANGEROUS_THRESHOLD=0.70

# ─── Ensemble Weights ─────────────────────────────────────────────────────────
EMAIL_WEIGHT=0.45
URL_WEIGHT=0.45
RULE_WEIGHT=0.10
