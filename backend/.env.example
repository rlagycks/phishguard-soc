# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./soc_phishing.db

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# GCP Console > APIs & Services > Credentials > OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── Gmail Watch ─────────────────────────────────────────────────────────────
# The Gmail account to monitor
GMAIL_ACCOUNT=your-test-account@gmail.com
# GCP Pub/Sub topic name (format: projects/<project-id>/topics/<topic-name>)
PUBSUB_TOPIC=projects/your-gcp-project/topics/gmail-alert-topic
# Token used to verify Pub/Sub push messages (any random string)
WEBHOOK_TOKEN=generate-a-random-secret-token-here

# ─── Dashboard URLs ───────────────────────────────────────────────────────────
# React dashboard URL used after Google OAuth. In production this can be your
# FastAPI origin, for example https://soc.example.com
FRONTEND_URL=http://localhost:5173
# Legacy Streamlit dashboard URL kept only while migrating
STREAMLIT_URL=http://localhost:8501

# ─── AI Models ────────────────────────────────────────────────────────────────
# BERT fine-tuned model directory (set to ../models/bert if using BERT)
NLP_MODEL_PATH=../models/bert
URL_MODEL_PATH=../models/url_model.pkl

# ─── Risk Thresholds ──────────────────────────────────────────────────────────
SUSPICIOUS_THRESHOLD=0.40
DANGEROUS_THRESHOLD=0.70

# ─── Ensemble Weights (must sum to 1.0) ───────────────────────────────────────
EMAIL_WEIGHT=0.45
URL_WEIGHT=0.45
RULE_WEIGHT=0.10
